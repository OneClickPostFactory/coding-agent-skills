{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneclickpostfactory.invalid/coding-agent-skills/evidence-bundle.schema.json",
  "title": "Coding Agent Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundleVersion",
    "bundleId",
    "generatedAt",
    "core",
    "replay",
    "entries",
    "regression",
    "changedState",
    "recommendedNextAction"
  ],
  "properties": {
    "bundleVersion": {
      "const": "1.0.0"
    },
    "bundleId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "core": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "currentVersion", "previousVersion"],
      "properties": {
        "id": {
          "const": "coding-agent-skills"
        },
        "currentVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "previousVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    },
    "replay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deterministic", "strategy"],
      "properties": {
        "deterministic": {
          "const": true
        },
        "strategy": {
          "const": "canonical-report-hash"
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "path", "sha256", "expectedStatus"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "kind": {
            "enum": ["evidence-pack", "adapter-upgrade-evidence"]
          },
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.env(?:\\.|/|$)).+\\.json$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "expectedStatus": {
            "enum": ["complete", "partial", "failed", "blocked", "pass", "warn", "fail"]
          }
        }
      }
    },
    "regression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baselineVersion", "targetVersion", "baselineEntries"],
      "properties": {
        "baselineVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "targetVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "baselineEntries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "status"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "status": {
                "enum": ["complete", "partial", "failed", "blocked", "pass", "warn", "fail"]
              }
            }
          }
        }
      }
    },
    "changedState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changed", "summary"],
      "properties": {
        "changed": {
          "const": false
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "recommendedNextAction": {
      "type": "string",
      "minLength": 1
    }
  }
}
