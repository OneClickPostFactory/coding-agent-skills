#!/usr/bin/env node
import { spawnSync } from "node:child_process";
import path from "node:path";
import { fileURLToPath } from "node:url";

const repoRoot = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "..");

const commands = {
  "validate-pack": {
    script: "scripts/validate-pack.mjs",
    args: () => ["."],
    usage: "coding-agent-skills validate-pack",
  },
  "validate-project": {
    script: "scripts/validate-project-adapters.mjs",
    args: ([projectRoot]) => [projectRoot],
    usage: "coding-agent-skills validate-project <project-root>",
    requiredArgs: 1,
  },
  "repo-map": {
    script: "scripts/render-adapter-repo-map.mjs",
    args: ([projectRoot]) => [projectRoot],
    usage: "coding-agent-skills repo-map <project-root>",
    requiredArgs: 1,
  },
  "route-trace": {
    script: "scripts/render-route-trace.mjs",
    args: ([projectRoot]) => [projectRoot],
    usage: "coding-agent-skills route-trace <project-root>",
    requiredArgs: 1,
  },
  "env-audit": {
    script: "scripts/render-env-audit.mjs",
    args: ([projectRoot]) => [projectRoot],
    usage: "coding-agent-skills env-audit <project-root>",
    requiredArgs: 1,
  },
  "secret-audit": {
    script: "scripts/render-secret-audit.mjs",
    args: ([projectRoot]) => [projectRoot],
    usage: "coding-agent-skills secret-audit <project-root>",
    requiredArgs: 1,
  },
  "api-contract-audit": {
    script: "scripts/render-api-contract-audit.mjs",
    args: ([projectRoot]) => [projectRoot],
    usage: "coding-agent-skills api-contract-audit <project-root>",
    requiredArgs: 1,
  },
  "migration-review": {
    script: "scripts/render-migration-review.mjs",
    args: ([projectRoot]) => [projectRoot],
    usage: "coding-agent-skills migration-review <project-root>",
    requiredArgs: 1,
  },
  "github-handoff": {
    script: "scripts/render-github-handoff.mjs",
    args: ([projectRoot]) => [projectRoot],
    usage: "coding-agent-skills github-handoff <project-root>",
    requiredArgs: 1,
  },
  "validate-adapters": {
    script: "scripts/validate-adapters.mjs",
    args: ([adapterRoot]) => [adapterRoot],
    usage: "coding-agent-skills validate-adapters <adapter-root>",
    requiredArgs: 1,
  },
};

function usage(exitCode = 0) {
  const lines = [
    "usage: coding-agent-skills <command> [args]",
    "",
    "commands:",
    "  validate-pack",
    "  validate-project <project-root>",
    "  repo-map <project-root>",
    "  route-trace <project-root>",
    "  env-audit <project-root>",
    "  secret-audit <project-root>",
    "  api-contract-audit <project-root>",
    "  migration-review <project-root>",
    "  github-handoff <project-root>",
    "  validate-adapters <adapter-root>",
    "",
    "local wrapper for the published coding-agent-skills package",
  ];
  const stream = exitCode === 0 ? process.stdout : process.stderr;
  stream.write(`${lines.join("\n")}\n`);
  process.exitCode = exitCode;
}

const [commandName, ...args] = process.argv.slice(2);
if (!commandName || commandName === "help" || commandName === "--help" || commandName === "-h") {
  usage(commandName ? 0 : 2);
} else if (!Object.hasOwn(commands, commandName)) {
  process.stderr.write(`unknown command: ${commandName}\n`);
  usage(2);
} else {
  const command = commands[commandName];
  if ((command.requiredArgs ?? 0) !== args.length) {
    process.stderr.write(`usage: ${command.usage}\n`);
    process.exitCode = 2;
  } else {
    const result = spawnSync(
      process.execPath,
      [path.join(repoRoot, command.script), ...command.args(args)],
      {
        cwd: repoRoot,
        encoding: "utf8",
        stdio: "inherit",
        shell: false,
      },
    );
    process.exitCode = result.status ?? 1;
  }
}
